+            ctx->n_failed++;
+        /* We reset the index, as there is no longer that part */
+        mm_sms_part_set_index ((MMSmsPart *)ctx->current->data, SMS_PART_INVALID_INDEX);
+
+        ctx->current = g_list_next (ctx->current);
+        delete_next_part (task);
+        return;
+    }
+
